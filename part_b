    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.svm import SVC\n",
        "from sklearn.metrics import accuracy_score, classification_report\n",
        "\n",
        "# 1. Load the file with your specific name\n",
        "# Make sure q1_heart_disease.csv is in your Colab files list\n",
        "df = pd.read_csv('q1_heart_disease.csv')\n",
        "\n",
        "# 2. Simple cleaning: Fill missing numbers with median\n",
        "df = df.fillna(df.median(numeric_only=True))\n",
        "\n",
        "# 3. Fill missing text categories with mode\n",
        "for col in df.select_dtypes(include=['object']):\n",
        "    df[col] = df[col].fillna(df[col].mode()[0])\n",
        "\n",
        "print(\"Step 1: File loaded and data is clean!\")"
      ],
      "metadata": {
