            "Step 1: File loaded and data is clean!\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# 1. Convert text to numbers (One-Hot Encoding)\n",
        "df_final = pd.get_dummies(df, drop_first=True)\n",
        "\n",
        "# 2. Separate Features (X) and Target (y)\n",
        "X = df_final.drop('heart_disease', axis=1)\n",
        "y = df_final['heart_disease']\n",
        "\n",
        "# 3. Split: 80% for Training, 20% for Testing\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)\n",
        "\n",
        "# 4. Standard Scaling (Crucial for SVM performance)\n",
        "scaler = StandardScaler()\n",
        "X_train_scaled = scaler.fit_transform(X_train)\n",
        "X_test_scaled = scaler.transform(X_test)\n",
        "\n",
        "print(\"Step 2: Data encoding and scaling is successful!\")"
      ],
      "metadata": {
        "colab": {
